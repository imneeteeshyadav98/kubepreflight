/kubepreflight
/findings.json
/report.md
/report.html
/rollback-assessment.json
/rollback-report.md
/rollback-report.html
/out/

# Console (web/) build tooling. web/dist IS committed on purpose — it's
# what go:embed reads (web/embed.go) so end users never need Node; see
# web/README.md for the required `npm run build` step after any web/src
# change.
/web/node_modules/
/web/tsconfig.tsbuildinfo

# Local real-EKS/demo runs. These can contain operator-specific cluster
# context, generated reports, and deliberately broken workload manifests.
/artifacts/
/broken-webhook.yaml
/demo-manifests/
/eks-demo.yaml
/pdb-lab.yaml
/report-clean*.md
/report-worst*.md
/report-clean*.json
/report-worst*.json
/upgrade-plan.json

# Demo output is generated locally on demand (see demo/README.md), never
# committed — a real scan's finding count moves with the product and a
# frozen capture goes stale fast. Ignored defensively in case a local run
# happens to land here, even though the documented reproduction command
# writes to the repo root (already covered by /findings.json etc. above).
/demo/sample-output/

# Same reasoning: a fresh capture every time this is run, not a frozen
# fixture. Only GIFs produced from a run are committed, never the raw
# evidence (see demo/live-eks/README.md).
/demo/live-eks/evidence/

# SEC-TRUST-002 live released-artifact smoke output. Raw evidence can contain
# cluster metadata and short-lived credentials; commit sanitized excerpts only
# when an explicit release audit asks for them.
/live-eks-evidence/

# Sales/business discovery-call material, not engineering source — kept
# outside the repo (see ~/kubepreflight-discovery-pack) to avoid growing
# the git history with screenshots and sample reports that go stale often.
/discovery-pack/
